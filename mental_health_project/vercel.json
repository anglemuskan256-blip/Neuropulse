{
  "buildCommand": "pip install --upgrade -r requirements.txt",
  "outputDirectory": "public",
  "framework": "flask",
  "python": {
    "version": "3.11"
  },
  "env": {
    "FLASK_ENV": "production",
    "PYTHONUNBUFFERED": "1",
    "FLASK_DEBUG": "0"
  },
  "functions": {
    "api/index.py": {
      "runtime": "python3.11"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}
